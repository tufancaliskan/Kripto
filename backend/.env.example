# Yerel geliştirme (SQLite — varsayılan)
DATABASE_URL=sqlite:///./morseacademy.db

# Render PostgreSQL — Dashboard'dan otomatik gelir, elle yazmayın:
# DATABASE_URL=postgresql://user:pass@host/dbname

SECRET_KEY=uzun-rastgele-bir-anahtar
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Render ortam değişkenleri:
# DATABASE_URL  → PostgreSQL bağlantısı (Render otomatik ekler)
# SECRET_KEY    → güçlü rastgele anahtar
# CORS_ORIGINS  → https://proje-adin.vercel.app
